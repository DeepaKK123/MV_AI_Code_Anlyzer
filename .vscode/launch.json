{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run setup.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/setup.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Streamlit App",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "app.py"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Test Parser",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/parser/unidata_parser.py",
            "args": ["unidata_source/ORD.PROCESS.B"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
